{
  "buildCommand": "node scripts/generate-seo.mjs && vite build && node scripts/inject-meta.mjs",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://plausible.io https://www.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: data:; connect-src 'self' https://www.google-analytics.com https://plausible.io https://www.clarity.ms" }
      ]
    }
  ],
  "redirects": [
    { "source": "/kategori/kuzhine", "destination": "/kategori/lifestyle", "statusCode": 301 },
    { "source": "/qyshme/receta-gatimi", "destination": "/kategori/lifestyle", "statusCode": 301 },
    { "source": "/qyshme/receta-gatimi/", "destination": "/kategori/lifestyle", "statusCode": 301 },
    { "source": "/femradd-voice/:path*", "destination": "/:path*", "permanent": true },
    { "source": "/horoskopi/", "destination": "/kategori/horoskopi", "permanent": true },
    { "source": "/horoskopi-shqip/", "destination": "/kategori/horoskopi", "permanent": true },
    { "source": "/dashuria/", "destination": "/kategori/dashuri", "permanent": true },
    { "source": "/letersia/", "destination": "/kategori/letersi", "permanent": true },
    { "source": "/poezi/", "destination": "/kategori/letersi", "permanent": true },
    { "source": "/parashikimi-i-motit/", "destination": "/kategori/moti", "permanent": true },
    { "source": "/moti-ne-gjirokaster/", "destination": "/artikull/gjirokastra", "permanent": true },
    { "source": "/moti-ne-korce/", "destination": "/artikull/korca", "permanent": true },
    { "source": "/moti-ne-malisheve/", "destination": "/artikull/moti-ne-malisheve-old", "permanent": true },
    { "source": "/kalendari-i-ramazanit/", "destination": "/artikull/kalendari-i-ramazanit-2023", "permanent": true },
    { "source": "/artikull/sa-eshte-numri-ideal-i-femijeve-per-prinderit", "destination": "/kategori/personale", "statusCode": 301 },
    { "source": "/wp-content/:path*", "destination": "/artikuj", "permanent": true },
    { "source": "/sq/:slug", "destination": "/artikull/:slug", "permanent": true },
    { "source": "/sq/:slug/", "destination": "/artikull/:slug", "permanent": true },
    { "source": "/:year(\\d{4})/:month(\\d{2})/:day(\\d{2})/:slug", "destination": "/artikull/:slug", "permanent": true },
    { "source": "/:year(\\d{4})/:month(\\d{2})/:day(\\d{2})/:slug/", "destination": "/artikull/:slug", "permanent": true },
    { "source": "/category/bukuri-dhe-mode/", "destination": "/kategori/lifestyle", "permanent": true },
    { "source": "/category/shendeti/", "destination": "/kategori/lifestyle", "permanent": true },
    { "source": "/category/dashuri-dhe-sex/", "destination": "/kategori/dashuri", "permanent": true },
    { "source": "/category/dieta-dhe-fitnessi/", "destination": "/kategori/lifestyle", "permanent": true },
    { "source": "/category/:slug/", "destination": "/kategori/:slug", "permanent": true },
    { "source": "/search/:path*", "destination": "/artikuj", "permanent": true },
    { "source": "/feed/:path*", "destination": "/rss.xml", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!assets|images|favicon|manifest|robots|sitemap|rss|og-image|apple-touch-icon).*)", "destination": "/index.html" }
  ]
}
